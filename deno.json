{
  "name": "@mcp/github-actions",
  "version": "1.0.0",
  "exports": "./main.ts",
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-run=gh main.ts",
    "dev": "deno run --watch --allow-net --allow-env --allow-run=gh main.ts",
    "compile": "deno compile --allow-net --allow-env --allow-run=gh -o github-actions-mcp main.ts",
    "check": "deno check main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "test": "deno test"
  },
  "imports": {
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@1.25.1",
    "zod": "npm:zod@3.25.76",
    "@std/assert": "jsr:@std/assert@1"
  },
  "compilerOptions": {
    "strict": true
  }
}
